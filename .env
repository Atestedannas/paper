# Server Configuration
SERVER_PORT=8002
SERVER_HOST=localhost
SERVER_MODE=development

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=paper_checker
DATABASE_SSL_MODE=disable

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRY_HOURS=24

# File Storage Configuration
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Log Configuration
LOG_PATH=./logs
LOG_LEVEL=info

# Security Configuration
SECURITY_ENCRYPTION_KEY=this-is-a-32-byte-key-for-dev-only

# WeChat OAuth + Payment Configuration
WECHAT_REDIRECT_URL=http://localhost:5173/auth/callback/wechat
WECHAT_APP_ID=wx0ab7ff03fe7f341d
WECHAT_APP_SECRET=b4a76fddceaf2ca85b81105bd6681e8b
WECHAT_MCH_ID=1608142420
WECHAT_API_KEY=qwertyuiop123456789ASDFGHJKL1234
WECHAT_API_V3_KEY=fufentong12345678910111213141516
WECHAT_SERIAL_NO=11378A6EB5FE1B7618D6FB98502E89F82F8B12A7
WECHAT_NOTIFY_URL=https://v3.api.fufentong.com/api/pay.WechatPay/callback

# ============================================================
# 支付宝支付配置（生产环境 - 福分通）
# ============================================================
# 生产 APPID
ALIPAY_APP_ID=2017090408548630
# 签名类型：RSA 或 RSA2（福分通为 RSA）
ALIPAY_SIGN_TYPE=RSA
# APP 私钥（PKCS1 格式，去掉头尾，拼成一行）
ALIPAY_APP_PRIVATE_
# 支付宝公钥（验签用，支付宝官方公钥，非自己的公钥）
ALIPAY_PUBLIC_KEY=
# 支付网关（生产）
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
# 异步通知地址（支付成功后支付宝 POST 到此地址，需公网可访问）
# 生产时改为真实域名: https://yourdomain.com/api/v1/payment/alipay/notify
ALIPAY_NOTIFY_URL=http://v3.api.fufentong.com/api/pay.AliPay/callback
# 同步跳转地址（支付成功后页面跳转）
ALIPAY_RETURN_URL=http://localhost:5173/payment/success
# OAuth 登录回调地址（扫码登录，与支付分开）
ALIPAY_REDIRECT_URL=http://localhost:5173/auth/callback/alipay
# 是否启用沙箱（测试用，true 时使用测试 APPID 和沙箱网关）
# 生产上线时改为 false
ALIPAY_SANDBOX_ENABLED=true

# ============================================================
# 支付宝沙箱测试配置（ALIPAY_SANDBOX_ENABLED=true 时生效）
# ============================================================
# 沙箱 APPID
ALIPAY_SANDBOX_APP_ID=2088102181253034
# 沙箱签名类型（沙箱使用 2048-bit 密钥，建议 RSA2）
ALIPAY_SANDBOX_SIGN_TYPE=RSA2
# 沙箱 APP 私钥（与主站不同，独立密钥对）
ALIPAY_SANDBOX_APP_PRIVATE_
# 沙箱网关
ALIPAY_SANDBOX_GATEWAY_URL=https://openapi.alipaydev.com/gateway.do
# 沙箱异步通知地址
ALIPAY_SANDBOX_NOTIFY_URL=http://mapi.fufentong.com/master/api/alipay/alipayNotifyUrl
# 沙箱同步跳转
ALIPAY_SANDBOX_RETURN_URL=http://mapi.fufentong.com/master/api/alipay/alipayReturnUrl

