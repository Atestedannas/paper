# Server Configuration
SERVER_PORT=8002
SERVER_HOST=0.0.0.0
SERVER_MODE=debug

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=paper_checker
DATABASE_SSL_MODE=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_MAX_IDLE_CONNECTIONS=5

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY_HOURS=24

# File Storage Configuration
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Log Configuration
LOG_PATH=./logs
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=104857600  # 100MB
LOG_FILE_MAX_AGE=30  # 30 days
LOG_FILE_MAX_BACKUPS=10

# ============================================================================
# 微信支付配置 (微信扫码支付 Native)
# ============================================================================
# 微信扫码支付（Native）需要以下配置：
# 1. 在微信支付商户平台(https://pay.weixin.qq.com)注册并开通Native支付
# 2. 获取AppID（公众号/小程序ID）和MchID（商户号）
# 3. 设置API密钥（在账户中心-API安全中设置）
# 4. 配置支付回调NotifyURL
# ============================================================================
WECHAT_APP_ID=your_wechat_app_id                    # 微信开放平台应用的AppID
WECHAT_MCH_ID=your_wechat_mch_id                    # 微信支付商户号
WECHAT_API_KEY=your_wechat_api_key                  # API密钥（32位字符串）
WECHAT_NOTIFY_URL=http://your_domain/api/payment/wechat/callback  # 支付回调通知URL

# ============================================================================
# 支付宝电脑网站支付配置 (支持扫码支付)
# ============================================================================
# 支付宝电脑网站支付需要以下配置：
# 1. 在支付宝开放平台(https://open.alipay.com)创建应用
# 2. 签约电脑网站支付产品
# 3. 生成RSA2密钥对（应用公钥和私钥）
# 4. 在支付宝开放平台配置应用公钥
# 5. 获取支付宝公钥
# 6. 配置回调URL
# ============================================================================
ALIPAY_APP_ID=your_alipay_app_id                    # 支付宝应用 APPID
ALIPAY_APP_PRIVATE_KEY=your_alipay_private_key      # 应用私钥（RSA2，可一行 Base64 或 PEM）
# 以下为开放平台「支付宝公钥」（上传应用公钥后页面展示），不是应用公钥本身
ALIPAY_PUBLIC_KEY=your_alipay_platform_public_key
ALIPAY_NOTIFY_URL=https://your_domain/api/v1/payment/alipay/callback  # 须公网 HTTPS，与路由一致
ALIPAY_RETURN_URL=https://your_domain/payment/result  # 电脑网站支付同步跳转（可选）
ALIPAY_REDIRECT_URL=https://your_domain/api/v1/auth/alipay/callback  # Alipay login OAuth callback
ALIPAY_QR_REDIRECT_URL=https://your_domain/api/v1/auth/alipay/callback  # Alipay desktop QR login callback; must be backend HTTPS
ALIPAY_AUTHORIZE_URL=https://open.auth.alipay.com/oauth2/publicAppAuthorize.htm
ALIPAY_SCOPE=auth_user
# 扫码当面付预下单 alipay.trade.precreate 需在开放平台签约「当面付」

# ============================================================================
# 微信沙箱环境配置 (开发测试用)
# ============================================================================
# 沙箱环境说明：
# 1. 微信沙箱环境需要单独申请
# 2. 沙箱环境和正式环境相互独立
# 3. 开发测试时建议先在沙箱环境验证
# ============================================================================
WECHAT_SANDBOX_ENABLED=false
WECHAT_API_KEY_3=your_sandbox_api_key_3
WECHAT_API_KEY_3_SECRET=your_sandbox_api_key_3_secret
WECHAT_SANDBOX_SIGN_KEY=your_sandbox_sign_key

# ============================================================================
# 支付宝沙箱环境配置 (开发测试用)
# ============================================================================
# 沙箱环境说明：
# 1. 支付宝沙箱环境自动提供，无需单独申请
# 2. 访问 https://open.alipay.com 选择沙箱环境
# 3. 使用沙箱账号登录测试
# ============================================================================
ALIPAY_SANDBOX_ENABLED=false
ALIPAY_SANDBOX_GATEWAY_URL=https://openapi.alipaydev.com/gateway.do  # 支付宝沙箱网关

# ============================================================================
# 支付类型说明
# ============================================================================
# 微信支付类型：
# - native: 扫码支付（生成二维码，用户扫描支付）[推荐]
# - jsapi:  JSAPI支付（微信内网页支付，需要openid）
#
# 支付宝支付类型：
# - page: 电脑网站支付（跳转到支付宝页面支付）[推荐]
# ============================================================================

# Security Configuration
SECURITY_ENCRYPTION_KEY=this-is-a-32-byte-key-for-encryption

# ============================================================================
# 使用示例
# ============================================================================
# 1. 微信Native支付请求示例：
# POST /api/payment
# {
#   "order_id": "uuid格式的订单ID",
#   "payment_method": "wechat",
#   "payment_type": "native"
# }
# 返回：包含 code_url（二维码链接）和 qr_code_url（二维码图片URL）

# 2. 支付宝电脑网站支付请求示例：
# POST /api/payment
# {
#   "order_id": "uuid格式的订单ID",
#   "payment_method": "alipay",
#   "payment_type": "page"
# }
# 返回：包含 payment_url（支付链接）和 qr_code_url（二维码图片URL）

# ============================================================================
# StyleFormatter 格式修正引擎配置（python-docx 样式引用引擎）
# ============================================================================
# 是否启用新的 python-docx 格式引擎（true=优先使用，false=使用旧版 unioffice V2）
FORMATTER_ENABLED=true
# Python 可执行文件路径（Linux: python3, Windows: python）
FORMATTER_PYTHON_BIN=python3
# style_formatter.py 脚本路径（留空=自动搜索）
FORMATTER_SCRIPT_PATH=
# 格式修正超时秒数
FORMATTER_TIMEOUT=120
# 样式验收失败后的自我修复轮数（0=只校验不修复，不自动再套样式）
FORMATTER_VALIDATE_MAX_REPAIR=3
# 修改稿标题（Heading 1–3 等）段落格式与黄金模板样式定义对齐轮数（0=关闭）
FORMATTER_TEMPLATE_PARITY_ROUNDS=3
# LibreOffice UNO 后处理（uno_formatter.py）：需 soffice + python3-uno
FORMATTER_UNO_ENABLED=false
FORMATTER_UNO_TIMEOUT=180
# UNO_MODE=normalize   # 仅更新目录/索引与域；apply_styles=再套段落样式（段落数须与 python-docx 一致）
# UNO_HOST=127.0.0.1
# UNO_PORT=2002
# .doc → .docx（上传与 V2 黄金模板）：优先 LibreOffice soffice；Windows 无 LibreOffice 时可回退 Microsoft Word（COM，需已安装 Word；WPS 无效）
# SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# DISABLE_WORD_DOC_CONVERT=1   # 仅使用 LibreOffice，禁用 Word 回退
# 高校样式 spec（可选；也可由业务传入 school_id 自动解析 config/schools/{id}*.spec.json）
# FORMATTER_SCHOOL_SPEC=/opt/paper/config/schools/cq-hr-university-2026.spec.json
# 验收：正文段 pStyle 与期望不一致时记为 warning 而非 error（仍可见于报告，但不阻塞 compliance_100）
# FORMATTER_VALIDATE_BODY_WARN_ONLY=1
# StyleFormatter 流水线末尾：按 direct_format_warnings 清除 run 直接格式（与 Shell 后校验一致）；默认开启，设为 0 关闭
# FORMATTER_CLEAR_DIRECT_FORMAT_WARNINGS=0

# 格式审计日志：日志中带 [PAPER_FORMAT_AUDIT] + JSON（Go 与 Python 统一前缀，便于 grep）
# PAPER_FORMAT_AUDIT_LOG=0
# StyleFormatter 逐段打印已应用的规则（段落很多，仅调试时开）
# PAPER_FORMAT_AUDIT_VERBOSE=1
# 审计日志里路径默认只写文件名；需要完整 Windows 路径时开启
# PAPER_FORMAT_AUDIT_FULL_PATHS=1
# Go 侧 [PAPER_FORMAT_AUDIT] 除控制台外追加写入的 .log 文件（相对进程 cwd，一般为 backend）；不设则 logs/paper_format_audit.log；设为 0/off 关闭写文件
 PAPER_FORMAT_AUDIT_FILE=logs/paper_format_audit.log
# 对同一 docPath + 相同 corrections 的并发 ApplyCorrectionsV2 合并为一次执行（避免双请求重复审计）；调试时可设为 0 关闭
# PAPER_V2_APPLY_DEDUPE=0
# logrus：JSON 行追加写入文件（不设则 logrus 仍为默认 stderr 文本）；ShellFill 等处的 logrus.WithFields 会进该文件
# LOGRUS_JSON_FILE=logs/logrus.jsonl
# 同时把 JSON 日志打到 stderr（便于本机调试）：1/true/yes
# LOGRUS_JSON_ALSO_STDERR=1
# 重庆人文（school_id=cq-hr-university）：若 uploads/templates 下存在文件名含「附件5」的 .docx/.doc，优先于 DB 的 golden_template_path 作为 StyleFormatter 黄金模板（使修改稿对齐附件5版式）
# DISABLE_CQHR_ATTACHMENT5_PRIORITY=1
# 模板壳 + 就地换字：复制校方模板 docx，仅替换段落文字（保留 w:pPr/节/页眉页脚）；失败则继续走 StyleFormatter / V2FormatEngine
# USE_TEMPLATE_SHELL_FILL=1
# SHELL_FILL_TIMEOUT_SEC=120
# Shell 成功后：对输出稿重新分类并跑 docvalidate + 标题 parity 差异统计（只读）；默认开启。关闭则仍直接返回 Shell 产物。
# SHELL_FILL_POST_VALIDATE=0
# 后校验未通过（或脚本/重分类失败）时丢弃 Shell 结果、改用 StyleFormatter；默认开启。设为 0 则即使未过验收也仍返回 Shell 产物。
# SHELL_FILL_FALLBACK_ON_VALIDATE_FAIL=0
# Shell 后校验子进程超时（秒），默认与 StyleFormatter 超时相同
# SHELL_POST_VALIDATE_TIMEOUT_SEC=120
# 后校验首轮未过时：对 Shell 产物就地跑 template_parity（与 StyleFormatter 同源），再验收一轮。设为 N>0 启用，轮数 N。
# SHELL_FILL_PARITY_REPAIR_ROUNDS=3
# 或仅开关：=1 且未设 SHELL_FILL_PARITY_REPAIR_ROUNDS 时，轮数沿用 FORMATTER_TEMPLATE_PARITY_ROUNDS（默认同 style_formatter，否则 3）
# SHELL_FILL_PARITY_REPAIR_ON_FAIL=1
# Shell 后校验未过时，自动多轮 repair_violations（与 style_formatter 一致），默认轮数同 FORMATTER_VALIDATE_MAX_REPAIR；设为 0 关闭
# SHELL_FILL_VALIDATE_REPAIR_ROUNDS=3
# Shell 后校验：按 direct_format_warnings 自动清除 run 直接格式（标题/正文等；跳过封面/目录/normative 段）。默认开启
# SHELL_FILL_CLEAR_DIRECT_FORMAT_WARNINGS=0
# 兼容旧名：仅当未设置上一项时生效，关闭则整条不清理
# SHELL_FILL_CLEAR_HEADING_DIRECT_FORMAT=0

# ============================================================================
# DeepSeek AI 智能分类配置（自进化段落分类系统）
# ============================================================================
# 从浏览器登录 chat.deepseek.com 后，在开发者工具 → Application → Cookies 中获取
DEEPSEEK_COOKIE=ds_session_id=your_session_id_here
# Bearer Token（可选）
DEEPSEEK_BEARER=
# 可选：从旧 paper/backend/.env 读取 DeepSeek 网页版配置；未设置时会尝试 D:\workpace\博客\paper\backend\.env
# PAPER_BACKEND_ENV_FILE=D:\workpace\博客\paper\backend\.env
# DEEPSEEK_ENV_FILE=D:\workpace\博客\paper\backend\.env
# 是否启用 AI 仲裁与模板画像总结（false=仅使用规则引擎+本地解析，不调用AI）
DEEPSEEK_ENABLED=true
# DeepSeek 网页版底层 HTTP/SSE 超时（秒）；模板画像总结和全文段落分类会复用该客户端
# DEEPSEEK_CHAT_TIMEOUT_SEC=360
# StyleFormatter 段落分类 LLM 精修等待时间（秒，5–600，默认 120）。过短会超时并退回规则分类，长论文易出现“校验分高但版式仍乱”
# DEEPSEEK_REFINER_TIMEOUT_SEC=180
# 单个文档最大 AI 调用次数
DEEPSEEK_MAX_CALLS_PER_DOC=20
# 累积新样本数达到此值后触发本地模型重训练
DEEPSEEK_RETRAIN_THRESHOLD=200
