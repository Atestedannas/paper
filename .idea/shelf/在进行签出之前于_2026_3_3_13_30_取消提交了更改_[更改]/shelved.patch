+	// 获取论文格式检查是否需要付费的配置
+	isPaperCheckPaid := true // 默认付费
+
+	if val, exists := configMap["paper_check_paid"]; exists {
+		if val == "false" || val == "0" {
+			isPaperCheckPaid = false
+		}
