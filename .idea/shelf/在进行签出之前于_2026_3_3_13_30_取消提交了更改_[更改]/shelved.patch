+			var text strings.Builder
+			for _, textMatch := range textMatches {
+				if len(textMatch) > 1 {
+					text.WriteString(textMatch[1])
+				}
+			}
+
+			paragraph := XMLParagraph{
+				Text: strings.TrimSpace(text.String()),
+			}
+
+			if paragraph.Text != "" {
+				paragraphs = append(paragraphs, paragraph)
+			}
+		}
+	}
