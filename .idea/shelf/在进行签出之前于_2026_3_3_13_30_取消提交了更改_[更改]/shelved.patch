+// ProcessingResult 处理结果
+type ProcessingResult struct {
+	Success         bool
+	OutputPath      string
+	ProcessingTime  int64
+	QualityScore    float64
+	IssuesFixed     int
+	IssuesRemaining int
+	DetailedReport  map[string]interface{}
+	Recommendations []string
+}
