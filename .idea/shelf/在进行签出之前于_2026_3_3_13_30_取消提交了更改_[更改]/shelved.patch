+	// 简单的正则匹配段落
+	re := regexp.MustCompile(`<w:p[^>]*>(.*?)</w:p>`)
+	matches := re.FindAllStringSubmatch(xmlContent, -1)
+
+	for _, match := range matches {
+		if len(match) > 1 {
+			paragraphContent := match[1]
