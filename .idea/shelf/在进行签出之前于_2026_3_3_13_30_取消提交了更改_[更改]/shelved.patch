+// FormatRule 格式规则
+type FormatRule struct {
+	Target     string            // 应用目标
+	Properties map[string]string // 格式属性
+	Priority   int               // 优先级（用于冲突解决）
+	Source     string            // 来源位置
+	Confidence float64           // 置信度
+}
