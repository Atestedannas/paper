+	// 读取document.xml内容
+	var documentXML string
+	for _, file := range r.File {
+		if file.Name == "word/document.xml" {
+			content, err := file.Open()
+			if err != nil {
+				return nil, err
+			}
+			defer content.Close()
+
+			buf := new(bytes.Buffer)
+			if _, err := io.Copy(buf, content); err != nil {
+				return nil, err
+			}
+			documentXML = buf.String()
+			break
+		}
+	}
