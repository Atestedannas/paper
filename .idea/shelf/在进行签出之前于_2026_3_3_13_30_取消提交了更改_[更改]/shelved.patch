+	// 应用字体规则
+	if fontRules, ok := rules["Font"].(map[string]interface{}); ok {
+		appliedRules++
+		if p.debug {
+			log.Printf("应用字体规则: %+v", fontRules)
+		}
+	}
+
+	// 统计总应用规则数
+	totalRules := 0
+	if bodyRules, ok := rules["ParagraphStyles"].([]interface{}); ok {
+		totalRules += len(bodyRules)
