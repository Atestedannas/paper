+	doc := &TemplateDocument{
+		Parts:    []DocumentPart{},
+		Styles:   make(map[string]interface{}),
+		Metadata: make(map[string]interface{}),
+	}
+
+	// 打开ZIP文件
+	r, err := zip.OpenReader(docPath)
+	if err != nil {
+		return nil, err
+	}
+	defer r.Close()
